{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"paths": {
			"@sveltejs/kit": ["../../../../../exports/public"],
			"types": ["../../../../../types/internal"],
			"$app/types": ["../../../../../types/ambient.d.ts"],
			"$app/paths/types.js": ["../../../../../runtime/app/paths/types.d.ts"]
		},
		"types": ["node"]
	},
	"include": ["./**/*.js", "./**/*.ts", ".svelte-kit/non-ambient.d.ts"],
	"exclude": ["..svelte-kit/**"]
}
