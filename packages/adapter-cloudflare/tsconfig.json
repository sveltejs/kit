{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		// `@cloudflare/vite-plugin`, `wrangler`, and `@cloudflare/workers-types`
		// are full of type errors we can't fix
		"skipLibCheck": true,
		"paths": {
			"@sveltejs/kit": ["../kit/types/index"]
		},
		// taken from the Cloudflare Workers TypeScript template https://github.com/cloudflare/workers-sdk/blob/main/packages/create-cloudflare/templates/hello-world/ts/tsconfig.json
		"target": "es2024",
		"lib": ["es2024"],
		"types": ["node"]
	},
	"include": [
		"index.js",
		"ambient.d.ts",
		"internal.d.ts",
		"vitest.config.js",
		"src/*",
		"test/utils.js"
	]
}
