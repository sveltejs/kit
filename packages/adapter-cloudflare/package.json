{
	"name": "@sveltejs/adapter-cloudflare",
	"version": "7.2.8",
	"description": "Adapts SvelteKit applications for Cloudflare Workers or Cloudflare Pages",
	"keywords": [
		"adapter",
		"cloudflare pages",
		"deploy",
		"hosting",
		"svelte",
		"sveltekit"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sveltejs/kit.git",
		"directory": "packages/adapter-cloudflare"
	},
	"license": "MIT",
	"homepage": "https://svelte.dev/docs/kit/adapter-cloudflare",
	"type": "module",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./index.js"
		},
		"./package.json": "./package.json"
	},
	"types": "index.d.ts",
	"files": [
		"files",
		"index.js",
		"utils.js",
		"index.d.ts",
		"ambient.d.ts"
	],
	"scripts": {
		"build": "rolldown -c",
		"lint": "prettier --check .",
		"format": "pnpm lint --write",
		"check": "tsc --skipLibCheck",
		"test:unit": "vitest run",
		"test:e2e": "pnpm build && pnpm -r --workspace-concurrency 1 --filter=\"./test/**\" test",
		"test": "pnpm test:unit && pnpm test:e2e",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@cloudflare/workers-types": "^4.20260312.0",
		"esm-env": "^1.2.2",
		"worktop": "0.8.0-next.18"
	},
	"devDependencies": {
		"@playwright/test": "catalog:",
		"@sveltejs/kit": "workspace:^",
		"@types/node": "catalog:",
		"rolldown": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^3.0.0",
		"wrangler": "^4.74.0",
		"@cloudflare/vite-plugin": "^1.29.0"
	}
}
