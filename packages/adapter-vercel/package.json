{
	"name": "@sveltejs/adapter-vercel",
	"version": "6.3.3",
	"description": "A SvelteKit adapter that creates a Vercel app",
	"keywords": [
		"adapter",
		"deploy",
		"hosting",
		"svelte",
		"sveltekit",
		"vercel"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sveltejs/kit.git",
		"directory": "packages/adapter-vercel"
	},
	"license": "MIT",
	"homepage": "https://svelte.dev/docs/kit/adapter-vercel",
	"type": "module",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./index.js"
		},
		"./package.json": "./package.json"
	},
	"types": "index.d.ts",
	"files": [
		"files",
		"index.js",
		"utils.js",
		"index.d.ts",
		"ambient.d.ts"
	],
	"scripts": {
		"lint": "prettier --check .",
		"format": "pnpm lint --write",
		"check": "tsc",
		"test:unit": "vitest run",
		"test:build": "cd test/apps/basic && pnpm build",
		"test": "pnpm test:unit && pnpm test:build"
	},
	"dependencies": {
		"@vercel/nft": "^1.3.2",
		"rolldown": "^1.0.0-rc.6"
	},
	"devDependencies": {
		"@sveltejs/kit": "workspace:^",
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^3.0.0"
	}
}
