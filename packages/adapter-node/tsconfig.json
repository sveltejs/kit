{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"target": "es2022",
		"module": "node16",
		"moduleResolution": "node16",
		"paths": {
			"@sveltejs/kit": ["../kit/types/index"]
		},
		"types": ["node"]
	},
	"include": [
		"index.js",
		"rolldown.config.js",
		"vitest.config.js",
		"src/**/*.js",
		"src/**/*.ts",
		"test/utils.js",
		"tests/**/*.js",
		"tests/**/*.ts",
		"./internal.d.ts",
		"rollup.config.js"
	],
	"exclude": ["smoke.spec_disabled.js"]
}
