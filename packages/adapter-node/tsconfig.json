{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"target": "es2022",
		"module": "node16",
		"moduleResolution": "node16",
		"paths": {
			"@sveltejs/kit": ["../kit/types/index"]
		},
		"types": ["node"]
	},
	"include": ["index.js", "src/**/*.js", "src/**/*.ts", "test/utils.js", "utils.js", "./*.ts"],
	"exclude": ["smoke.spec_disabled.js"]
}
