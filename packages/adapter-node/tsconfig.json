{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"target": "es2022",
		"module": "node16",
		"moduleResolution": "node16",
		"paths": {
			"@sveltejs/kit": ["../kit/types/index"]
		},
		"types": ["node"]
	},
	"include": [
		"index.js",
		"src/**/*.js",
		"tests/**/*.js",
		"tests/**/*.ts",
		"internal.d.ts",
		"utils.js"
	],
	"exclude": ["tests/smoke.spec_disabled.js"]
}
